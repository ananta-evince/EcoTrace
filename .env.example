# ─── Database (Neon / Vercel Postgres / local Docker) ───
# Local Docker: postgresql://ecotrace:ecotrace@localhost:5432/ecotrace
# Neon pooled URL goes in DATABASE_URL; unpooled URL in DIRECT_URL
DATABASE_URL="postgresql://user:password@localhost:5432/ecotrace"
DIRECT_URL="postgresql://user:password@localhost:5432/ecotrace"

# ─── Auth (required) ───
# Local: http://localhost:3000 | Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="generate-a-secure-random-string-at-least-32-chars"
AUTH_SECRET="generate-a-secure-random-string-at-least-32-chars"

# ─── Optional ───
# Google Gemini — AI insights (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
